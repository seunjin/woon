{
  "name": "woon-monorepo",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm --parallel --filter './packages/*' --filter @woon-ui/storybook dev",
    "dev:storybook": "pnpm --filter @woon-ui/storybook dev",
    "build:storybook": "pnpm --filter @woon-ui/storybook build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "test:package": "pnpm --filter @woon-ui/cli test:package",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "lefthook": "^2.1.4",
    "typescript": "^5.7.0"
  },
  "onlyBuiltDependencies": [
    "esbuild"
  ]
}
