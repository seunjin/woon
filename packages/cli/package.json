{
  "name": "@woon-ui/cli",
  "version": "0.2.0",
  "description": "CLI for scaffolding Base UI overlay renderers for Woon",
  "type": "module",
  "license": "MIT",
  "bin": {
    "woon": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
